[Unit]
Description=Pleiades nspawn Container (gentoo)
Documentation=https://github.com/Zheke32174/pleiades-container
After=network.target local-fs.target
Wants=systemd-networkd.service

[Service]
Type=notify
ExecStart=/usr/bin/systemd-nspawn --keep-unit --boot --network-veth -M gentoo -D ${PLEIADES_ROOT:-/data/data/com.termux/files/home/pleiades}/rootfs
ExecStop=/usr/bin/machinectl poweroff gentoo
KillMode=mixed
Restart=always
RestartSec=10s
WatchdogSec=30s
TasksMax=infinity
CPUQuota=400%

[Install]
WantedBy=multi-user.target
